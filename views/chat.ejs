<!DOCTYPE html>
<html>
<head>
    <title>Chat</title>
    <script>
        let socket;
        let phase = 'Day';
        let heartbeatTimer;
        let currentSkill = null;
        let currentJob = 'Novice';
        let selectedTarget = '';

        const harmfulStatusLabels = {
            poison: 'poisoned',
            arcane_pin: 'pinned',
            marked: 'marked'
        };

        const helpfulStatusLabels = {
            ward: 'warded',
            bless: 'blessed'
        };

        function getStatusLabel(effectType) {
            return harmfulStatusLabels[effectType] || helpfulStatusLabels[effectType] || effectType;
        }

        function isSkillSystemMessage(message) {
            return /\b(scrounges|wards|power strikes|doses|patches up|surveys|pins|marks|blesses)\b/i.test(message);
        }

        function setText(parent, text) {
            const span = document.createElement('span');
            span.textContent = text;
            parent.appendChild(span);
            return span;
        }

        function redirectIfDead(response) {
            if (response.status === 410) {
                response.json()
                    .then(data => {
                        window.location.href = data.redirect || '/death';
                    })
                    .catch(() => {
                        window.location.href = '/death';
                    });
                return true;
            }
            return false;
        }

        function redirectIfResponseLandedOnDeath(response) {
            if (response.redirected && new URL(response.url).pathname === '/death') {
                window.location.href = '/death';
                return true;
            }
            return false;
        }

        function renderMessage(msg) {
            const messageElement = document.createElement('div');
            const isSystem = msg.username === 'System';
            if (isSystem) {
                messageElement.classList.add('system-message');
                if (isSkillSystemMessage(msg.message)) {
                    messageElement.classList.add('skill-message');
                }
                messageElement.textContent = `${msg.timestamp} - system: ${msg.message}`;
                return messageElement;
            }

            const activeStatuses = (msg.statusEffects || []).map(getStatusLabel);
            setText(messageElement, `${msg.timestamp} - `);
            const username = document.createElement('button');
            username.type = 'button';
            username.className = 'message-username';
            username.textContent = msg.username;
            username.addEventListener('click', () => selectTarget(msg.username));
            messageElement.appendChild(username);
            if (msg.job) {
                setText(messageElement, ` [${String(msg.job).toLowerCase()}]`);
            }
            activeStatuses.forEach(status => {
                setText(messageElement, ` [${status}]`);
            });
            setText(messageElement, `: ${msg.message}`);
            return messageElement;
        }

        // Function to fetch and display messages
        function loadMessages() {
      const row = '<%= row %>';
      const col = '<%= col %>';

      fetch(`/messages/${row}/${col}`)
        .then(response => {
            if (redirectIfDead(response)) {
                throw new Error('You died');
            }
            if (!response.ok) {
                throw new Error('Messages unavailable');
            }
            return response.json();
        })
        .then(data => {
                const messagesDiv = document.getElementById('messages');
                messagesDiv.innerHTML = '';
                data.forEach(msg => {
                    messagesDiv.appendChild(renderMessage(msg));
                });
                scrollToBottom();
                })
        .catch(() => {
                const messagesDiv = document.getElementById('messages');
                messagesDiv.textContent = 'Messages are unavailable in this room right now.';
        });
            }

        // Function to fetch and display user attributes
        function loadUserAttributes() {
            fetch('/user-attributes')
                .then(response => {
                    if (redirectIfDead(response)) {
                        throw new Error('You died');
                    }
                    return response.json();
                })
                .then(data => {
                    const attributesDiv = document.getElementById('attributes');
                    const effective = data.effectiveStats || data;
                    currentSkill = data.skill || null;
                    currentJob = data.job || 'Novice';
                    attributesDiv.innerHTML = `
                        <p>Job: ${data.job || 'Novice'}</p>
                        <p>Health: ${effective.health}/${effective.maxHealth}</p>
                        <p>Stamina: ${effective.stamina}/${effective.maxStamina}</p>
                        <p>Speed: ${effective.speed}</p>
                        <p>Strength: ${effective.strength}</p>
                        <p>Intelligence: ${effective.intelligence}</p>
                        <p>Level: ${data.level}</p>
                        <p>Gold: ${data.gold !== undefined ? data.gold : 0}</p>
                    `;
                    const skillSelect = document.getElementById('skill-id');
                    if (skillSelect && currentSkill) {
                        skillSelect.innerHTML = '';
                        const option = document.createElement('option');
                        option.value = currentSkill.id;
                        option.textContent = currentSkill.label;
                        skillSelect.appendChild(option);
                    }
                    const jobSelect = document.getElementById('job-select');
                    if (jobSelect) {
                        Array.from(jobSelect.options).forEach(option => {
                            option.selected = option.value === currentJob;
                        });
                    }
                });
        }

        // Function to fetch and display the global tick value
        function loadTick() {
            fetch('/tick')
                .then(response => response.json())
                .then(data => {
                    const tickDiv = document.getElementById('tick');
                    const tickValue = data.tick;
                    const phaseDiv = document.getElementById('phase');

                    // Update the phase based on the tick value
                    phase = tickValue % 100 < 50 ? 'Day' : 'Night';

                    tickDiv.textContent = `Global Tick: ${tickValue}`;
                    phaseDiv.textContent = `Phase: ${phase}`;
                });
        }

        function setParagraph(parent, text) {
            const paragraph = document.createElement('p');
            paragraph.textContent = text;
            parent.appendChild(paragraph);
        }

        function loadRoomEcology() {
            const row = '<%= row %>';
            const col = '<%= col %>';

            fetch(`/room-ecology/${row}/${col}`)
                .then(response => {
                    if (redirectIfDead(response)) {
                        throw new Error('You died');
                    }
                    return response.json();
                })
                .then(data => {
                    const toolbar = document.getElementById('room-ecology-toolbar');
                    const featureLabels = data.features.map(feature => {
                        if (feature.active === false) {
                            return `${feature.label} (dormant)`;
                        }
                        return feature.label;
                    });
                    const traceLabels = data.traceSummary.labels.length > 0 ? data.traceSummary.labels : ['none'];
                    const effectLabels = data.effects && data.effects.length > 0
                        ? data.effects.map(effect => effect.label || effect.type)
                        : ['none'];

                    toolbar.innerHTML = '';
                    setParagraph(toolbar, `Room: ${data.room.row}, ${data.room.col}`);
                    setParagraph(toolbar, `Features: ${featureLabels.join(', ')}`);
                    setParagraph(toolbar, `Systems: ${effectLabels.join(', ')}`);
                    setParagraph(toolbar, `Traces: ${traceLabels.join(', ')}`);
                    if (data.stock && data.stock.length > 0) {
                        setParagraph(toolbar, `Stock: ${data.stock.map(item => `${item.name} ${item.price}g`).join(', ')}`);
                    }
                    if (data.commands && data.commands.length > 0) {
                        setParagraph(toolbar, `Commands: ${data.commands.join(', ')}`);
                    }
                    if (data.innAccess && data.innAccess.required) {
                        setParagraph(toolbar, `Inn: ${data.innAccess.paid ? 'paid' : `${data.innAccess.fee}g`}`);
                    }
                    if (data.activeRound) {
                        setParagraph(toolbar, `Dice pool: ${data.activeRound.pool}g, closes in ${data.activeRound.remainingTicks} ticks`);
                    }
                    setParagraph(toolbar, `Reset: ${new Date(data.nextResetAt).toUTCString()}`);
                    const roomDescription = document.createElement('p');
                    roomDescription.className = 'room-description';
                    roomDescription.textContent = data.description;
                    toolbar.appendChild(roomDescription);
                    const jobControls = document.getElementById('job-controls');
                    const isGuild = data.effects && data.effects.some(effect => effect.type === 'guild');
                    if (jobControls) {
                        jobControls.style.display = isGuild ? 'flex' : 'none';
                    }
                });
        }

        function heartbeatRoom() {
            const row = '<%= row %>';
            const col = '<%= col %>';

            fetch(`/room-presence/${row}/${col}`, {
                method: 'POST'
            }).catch(() => {});
        }

        // Load messages, user attributes, and tick when the page loads
        window.onload = function() {
            heartbeatRoom();
            loadMessages();
            loadUserAttributes();
            loadTick();
            loadRoomEcology();
            heartbeatTimer = setInterval(heartbeatRoom, 15000);

            // Set up WebSocket connection
            const socketProtocol = window.location.protocol === 'https:' ? 'wss://' : 'ws://';
            socket = new WebSocket(socketProtocol + window.location.host);

            socket.onmessage = function(event) {
                const message = JSON.parse(event.data);
                loadMessages();
                loadRoomEcology();
            };
        };

        function updateTargetHint() {
            const messageInput = document.getElementById('message');
            const clearTargetButton = document.getElementById('clear-target');
            if (!messageInput) {
                return;
            }
            messageInput.placeholder = selectedTarget
                ? `Currently targeting ${selectedTarget}`
                : 'Message';
            if (clearTargetButton) {
                clearTargetButton.style.display = selectedTarget ? 'inline-block' : 'none';
                clearTargetButton.textContent = selectedTarget ? `Untarget ${selectedTarget}` : 'Untarget';
            }
        }

        function selectTarget(username) {
            selectedTarget = username;
            updateTargetHint();
            const messageInput = document.getElementById('message');
            if (messageInput) {
                messageInput.focus();
            }
        }

        function clearTarget() {
            selectedTarget = '';
            updateTargetHint();
            const messageInput = document.getElementById('message');
            if (messageInput) {
                messageInput.focus();
            }
        }

        function getMentionTarget(message) {
            const match = message.match(/@([A-Za-z0-9_-]+)/);
            return match ? match[1] : '';
        }

        function getActionMessage(message, attack) {
            const trimmed = message.trim();
            if (!attack) {
                return message;
            }
            const target = getMentionTarget(trimmed) || selectedTarget;
            if (!target) {
                return message;
            }
            if (trimmed.includes(target)) {
                return message;
            }
            return trimmed ? `${trimmed} @${target}` : `@${target}`;
        }

        // Function to submit a new message
        function submitMessage(event, attack = false) {
            event.preventDefault();
            const messageInput = document.getElementById('message');
            const message = messageInput.value;
            const row = '<%= row %>';
            const col = '<%= col %>';
            const actionMessage = getActionMessage(message, attack);

            if (!actionMessage.trim()) {
                return;
            }

            if (message.trim() === '/dig') {
            // ... (existing code)
            } else {
            const endpoint = attack ? `/attack/${row}/${col}` : `/chat/${row}/${col}`;
            fetch(endpoint, {
                method: 'POST',
                headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `message=${encodeURIComponent(actionMessage)}`,
            })
            .then(response => {
                if (redirectIfResponseLandedOnDeath(response)) {
                    return;
                }
                if (!response.ok) {
                    return response.text().then(message => {
                        throw new Error(message);
                    });
                }
                messageInput.value = '';
                updateTargetHint();
                heartbeatRoom();
                loadMessages();
                loadUserAttributes();
                loadTick();
                loadRoomEcology();
            })
            .catch(error => {
                window.alert(error.message);
            });
            }
        }

        function submitSkill(event) {
            event.preventDefault();
            const row = '<%= row %>';
            const col = '<%= col %>';
            const skillSelect = document.getElementById('skill-id');
            const messageInput = document.getElementById('message');
            const skillId = skillSelect.value;
            const targetUsername = getMentionTarget(messageInput.value) || selectedTarget;

            fetch(`/skill/${row}/${col}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `skillId=${encodeURIComponent(skillId)}&targetUsername=${encodeURIComponent(targetUsername)}`,
            })
            .then(response => {
                if (redirectIfResponseLandedOnDeath(response)) {
                    return;
                }
                if (!response.ok) {
                    return response.text().then(message => {
                    throw new Error(message);
                    });
                }
                updateTargetHint();
                heartbeatRoom();
                loadMessages();
                loadUserAttributes();
                loadTick();
                loadRoomEcology();
            })
            .catch(error => {
                window.alert(error.message);
            });
        }

        function submitJobChange(event) {
            event.preventDefault();
            const row = '<%= row %>';
            const col = '<%= col %>';
            const jobSelect = document.getElementById('job-select');
            const job = jobSelect.value;

            fetch(`/job/${row}/${col}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `job=${encodeURIComponent(job)}`,
            })
            .then(response => {
                if (!response.ok) {
                    return response.text().then(message => {
                        throw new Error(message);
                    });
                }
                heartbeatRoom();
                loadMessages();
                loadUserAttributes();
                loadTick();
                loadRoomEcology();
            })
            .catch(error => {
                window.alert(error.message);
            });
        }

        document.addEventListener('DOMContentLoaded', function() { 
        // Add event listener for keydown event
            document.getElementById('message').addEventListener('keydown', function(event) {
            if ((event.altKey || event.metaKey) && event.key === 'Enter') {
                submitMessage(event, true); // Send message as an attack
            }
        });
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape' && selectedTarget) {
                clearTarget();
            }
        });
        updateTargetHint();
        });

        // Function to scroll to the bottom of the messages
        function scrollToBottom() {
            const messagesDiv = document.getElementById('messages');
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }
    </script>
    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .hud {
            display: flex;
            flex-direction: row;
            gap: 1em;
            background-color: #ffffff;
            padding: 0 .5em;
        }

        #room-ecology-toolbar {
            flex-wrap: wrap;
            gap: .4em 1em;
            border-top: 1px solid #d9d9d9;
            border-bottom: 1px solid #d9d9d9;
            padding: .5em;
        }

        #room-ecology-toolbar > p {
            margin: 0;
        }

        #room-ecology-toolbar .room-description {
            flex-basis: 100%;
            color: #333333;
            margin-top: .35em;
        }

        form {
            display: flex;
            padding: 1em 0;
            gap: .5em;
            width: 100%;
        }

        #attributes {
            display: flex;
            flex-direction: row;
            gap: 1em;
            padding: 1em 0;
        }

        #attributes > p {
            margin: 0;
        }

        .chat {
            flex: 1;
            display: flex;
            flex-direction: column-reverse;
            overflow-y: auto;
            padding: 1em;
            background-color: #ffffff;
        }
        input {
            width: 100%;
        }

        #job-controls {
            align-items: center;
        }

        .system-message {
            color: #777777;
        }

        .skill-message {
            color: #6f4aa5;
        }

        .message-username {
            border: 0;
            background: transparent;
            color: #0645ad;
            cursor: pointer;
            font: inherit;
            padding: 0;
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="hud">
        <p><a href="/success">World Map</a></p>
        <p><a href="/character">Status</a></p>
        <div id="attributes"></div>
        <p id="tick"></p>
        <p id="phase"></p>
    </div>
    <div class="hud" id="room-ecology-toolbar"></div>
    <div class="hud" id="job-controls" style="display: none;">
        <select id="job-select" name="job">
            <option value="Novice">Novice</option>
            <option value="Paladin">Paladin</option>
            <option value="Fighter">Fighter</option>
            <option value="Chemist">Chemist</option>
            <option value="Dungeoneer">Dungeoneer</option>
            <option value="Mage">Mage</option>
            <option value="Assassin">Assassin</option>
            <option value="Cleric">Cleric</option>
        </select>
        <button type="button" onclick="submitJobChange(event)">Change Job</button>
    </div>
    <div class="chat">
        <div id="messages"></div>
    </div>
    <div class="hud">
        <form onsubmit="submitMessage(event)">
            <input type="text" id="message" name="message">
            <button type="button" id="clear-target" onclick="clearTarget()" style="display: none;">Untarget</button>
            <button type="submit" onclick="submitMessage(event, false)">Send</button>
            <button type="submit" onclick="submitMessage(event, true)">Attack</button>
            <button type="button" onclick="submitSkill(event)">Skill</button>
            <select id="skill-id" name="skillId"></select>
        </form>
    </div>
</body>
</html>
